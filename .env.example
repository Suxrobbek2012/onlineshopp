# ─── Server ───────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ─────────────────────────────────
# MongoDB Atlas: mongodb+srv://<user>:<pass>@cluster.mongodb.net/online-shop
# Local:         mongodb://localhost:27017/online-shop
MONGODB_URI=mongodb://localhost:27017/online-shop

# ─── JWT ──────────────────────────────────────
# O'zgartiring! Kamida 32 ta belgi
JWT_SECRET=your_super_secret_jwt_key_change_this_min_32_chars
JWT_EXPIRE=7d

# ─── Telegram Bot ─────────────────────────────
# @BotFather dan oling: /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_from_botfather
# @userinfobot ga /start yuboring — ID olasiz
TELEGRAM_ADMIN_CHAT_ID=your_admin_telegram_chat_id

# ─── Frontend URL (CORS) ──────────────────────
FRONTEND_URL=http://localhost:5500
